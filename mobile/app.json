{
  "expo": {
    "name": "Durian Lens",
    "slug": "durian-lens",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/durian-lens-logo.jpg",
    "scheme": "com.durianlens.app",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/durian-lens-logo.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#2E7D32"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.durianlens.app"
    },
    "android": {
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/durian-lens-logo.jpg",
        "backgroundColor": "#2E7D32"
      },
      "package": "com.durianlens.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Durian Lens to access your camera to scan durians."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Durian Lens to access your photos to upload durian images."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Durian Lens to use your location to tag scan locations."
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "a9794968-e722-4569-ae32-b37ec621a313"
      }
    }
  }
}
