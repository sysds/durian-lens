# Server
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://durian_user:devpassword@postgres:5432/durian_lens
DB_PASSWORD=devpassword

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=change-me-in-production-min-32-chars-long
JWT_REFRESH_SECRET=change-me-too-min-32-chars-long

# AWS S3 — leave blank to use local file storage in dev
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY
S3_BUCKET=your-bucket-name

# ML Service
ML_SERVICE_URL=http://ml-service:8000

# CORS
ALLOWED_ORIGINS=http://localhost:19006,http://localhost:3001
